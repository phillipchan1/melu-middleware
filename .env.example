PORT=3000
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=your_model_deployment_name
AZURE_OPENAI_API_VERSION=2024-10-21

# Supabase (service role for server-side DB access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# CORS (comma-separated origins; patterns for preview deployments)
ALLOWED_ORIGINS=https://melu-app.vercel.app
ALLOWED_ORIGIN_PATTERNS=^https://melu-app.*\.vercel\.app$
